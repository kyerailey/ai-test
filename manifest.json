{
    "name": "Kye Changes",
    "version": "1.0",
    "permissions": ["scripting", "activeTab", "downloads"],
    "manifest_version": 3,
    "action": {
        "default_popup": "popup.html"
    },
    "web_accessible_resources": [
    {
      "resources": ["class_requirements.json", "libs/pdf-lib.min.js", "assets/Senior_Checkout.pdf"],
      "matches": ["<all_urls>"]
    }
  ]
}
